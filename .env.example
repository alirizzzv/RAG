# ============ LLM provider ============
# Swap the entire LLM backend by changing this ONE line.
# Options:
#   google_genai:gemini-1.5-flash          (free tier)
#   groq:llama-3.3-70b-versatile           (free tier)
#   anthropic:claude-3-5-haiku-latest      (paid)
#   openai:gpt-4o-mini                     (paid)
LLM_MODEL=google_genai:gemini-1.5-flash

# Provide the key for whichever provider you selected above (only one needed):
GOOGLE_API_KEY=
GROQ_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ============ Embeddings (local, free, offline) ============
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ============ Vector store ============
CHROMA_DIR=./data/chroma

# ============ Sandbox ============
# docker      = strong isolation (local dev)
# subprocess  = portable fallback (HF Spaces / no-docker envs)
SANDBOX_BACKEND=subprocess
SANDBOX_TIMEOUT_SECONDS=10
CODE_AGENT_MAX_RETRIES=3

# ============ Guardrails (protect the public demo's shared LLM quota) ============
MAX_QUESTION_CHARS=2000
RATE_LIMIT_PER_SESSION=15
RATE_LIMIT_GLOBAL=60
RATE_LIMIT_WINDOW_SECONDS=60
